# Copier en .env (local) ou définir ces variables dans Coolify (production).

# Secret pour signer les sessions de connexion.
# En PRODUCTION : générer une longue chaîne aléatoire (ex. `openssl rand -base64 32`).
AUTH_SECRET=changez-moi-en-production

# Chemin du fichier de base de données SQLite.
# En local : laisser vide (par défaut ./data/shift.db).
# En PRODUCTION (Coolify) : pointer vers un VOLUME PERSISTANT pour que les
# comptes ne soient pas perdus à chaque déploiement, ex. /app/data/shift.db
# DATABASE_PATH=/app/data/shift.db
